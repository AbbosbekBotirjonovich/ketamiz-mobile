  "item": [
    {
      "name": "Apply your docs to become a driver",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var template = `",
              "<style type=\"text/css\">",
              "    .tftable {font-size:14px;color:#333333;width:100%;border-width: 1px;border-color: #87ceeb;border-collapse: collapse;}",
              "    .tftable th {font-size:18px;background-color:#87ceeb;border-width: 1px;padding: 8px;border-style: solid;border-color: #87ceeb;text-align:left;}",
              "    .tftable tr {background-color:#ffffff;}",
              "    .tftable td {font-size:14px;border-width: 1px;padding: 8px;border-style: solid;border-color: #87ceeb;}",
              "    .tftable tr:hover {background-color:#e0ffff;}",
              "</style>",
              "",
              "<table class=\"tftable\" border=\"1\">",
              "    <tr>",
              "        <th>Driving License Number</th>",
              "        <th>Driving License Expiration Date</th>",
              "        <th>Birthday</th>",
              "        <th>Region ID</th>",
              "        <th>District ID</th>",
              "        <th>Quarter ID</th>",
              "        <th>Home Address</th>",
              "        <th>Vehicle Number</th>",
              "        <th>Car Model</th>",
              "        <th>Car Color ID</th>",
              "        <th>Tech Passport Number</th>",
              "        <th>Seats</th>",
              "    </tr>",
              "    <tr>",
              "        <td>{{response.driving_license_number}}</td>",
              "        <td>{{response.driving_license_expiration_date}}</td>",
              "        <td>{{response.birthday}}</td>",
              "        <td>{{response.region_id}}</td>",
              "        <td>{{response.district_id}}</td>",
              "        <td>{{response.quarter_id}}</td>",
              "        <td>{{response.home_address}}</td>",
              "        <td>{{response.vehicle_number}}</td>",
              "        <td>{{response.car_model}}</td>",
              "        <td>{{response.car_color_id}}</td>",
              "        <td>{{response.tech_passport_number}}</td>",
              "        <td>{{response.seats}}</td>",
              "    </tr>",
              "</table>",
              "`;",
              "",
              "function constructVisualizerPayload() {",
              "    return { response: pm.response.json() };",
              "}",
              "",
              "pm.visualizer.set(template, constructVisualizerPayload());"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
