# Fastlane Match sozlamalari.
# Lokalda AbbosbekBotirjonovich SSH host orqali ishlaydi.
# CI'da bu qiymat MATCH_GIT_URL env orqali ustidan yoziladi.
git_url(ENV["MATCH_GIT_URL"] || "git@AbbosbekBotirjonovich:AbbosbekBotirjonovich/ketamiz-ios-certs.git")
storage_mode("git")

type("appstore")            # distribution sertifikat + App Store provisioning
app_identifier(["uz.ketamiz.app"])

# CI'da sertifikatlar faqat o'qiladi, yangisi yaratilmaydi (xavfsizlik).
# Sertifikatlar allaqachon yaratilgan; yangisi kerak bo'lsa, vaqtincha
# false qilib `match appstore` ni lokalda qayta ishga tushiring.
readonly(true)
