# Fastlane lane'lari — iOS build va TestFlight'ga yuklash.
# CI'da `bundle exec fastlane ios beta` chaqiriladi.

default_platform(:ios)

platform :ios do
  # App Store Connect API key'ni Secrets'dagi qiymatlardan tayyorlaydi.
  # ENV o'zgaruvchilar GitHub Actions workflow'da o'rnatiladi.
  def asc_api_key
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_KEY_P8"],
      is_key_content_base64: false,
      in_house: false
    )
  end

  desc "Build va TestFlight'ga yuklash"
  lane :beta do
    api_key = asc_api_key

    # CI runner'da Match sertifikatni o'rnatish uchun vaqtinchalik keychain
    # kerak (default keychain bloklangan). Lokalda CI=true bo'lmaydi, shuning
    # uchun Mac'ning login keychain'i ishlatiladi.
    keychain_name = nil
    keychain_password = nil
    if ENV["CI"]
      keychain_name = "fastlane_tmp.keychain"
      keychain_password = "ci_temp_password"
      create_keychain(
        name: keychain_name,
        password: keychain_password,
        default_keychain: true,
        unlock: true,
        timeout: 3600,
        lock_when_sleeps: false
      )
    end

    # Match orqali distribution sertifikat + provisioning profilni tiklash.
    # readonly: CI hech qachon yangi sertifikat yaratmaydi.
    match(
      type: "appstore",
      readonly: true,
      api_key: api_key,
      keychain_name: keychain_name,
      keychain_password: keychain_password
    )

    # Loyiha CODE_SIGN_STYLE=Automatic bilan keladi, lekin Match manual
    # imzolash ishlatadi. Build'dan oldin Runner target'ni manual rejimga
    # o'tkazib, Match yaratgan profilga ulaymiz (aks holda ARCHIVE FAILED).
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      team_id: "DJ6Z29BM4D",
      code_sign_identity: "Apple Distribution",
      bundle_identifier: "uz.ketamiz.app",
      profile_name: "match AppStore uz.ketamiz.app",
      targets: ["Runner"]
    )

    # IPA build qilish (imzolangan).
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          "uz.ketamiz.app" => "match AppStore uz.ketamiz.app"
        }
      }
    )

    # TestFlight'ga yuklash (review'siz, sinovchilar uchun).
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  # ⚠️ HALI ISHLATILMAYDI — kelajakda App Store'ga avtomatik chiqarish uchun.
  #
  # Yoqishdan OLDIN App Store Connect'da quyidagilar TO'LIQ bo'lishi shart:
  #   - Metadata (tavsif, kalit so'zlar, kategoriya, maxfiylik siyosati URL)
  #   - Skrinshotlar (har xil ekran o'lchamlari uchun)
  #   - App Privacy anketa, yosh reytingi, export compliance
  #   - Birinchi versiya KAMIDA BIR MARTA qo'lda submit qilingan bo'lsin
  #
  # Yoqish: ios-release.yml workflow'da `fastlane ios beta` o'rniga
  # `fastlane ios release` yozing (yoki yangi tag namunasi qo'shing).
  desc "App Store'ga yuklab, review'ga jo'natish (metadata to'liq bo'lishi shart)"
  lane :release do
    api_key = asc_api_key

    if ENV["CI"]
      keychain_name = "fastlane_tmp.keychain"
      keychain_password = "ci_temp_password"
      create_keychain(
        name: keychain_name, password: keychain_password,
        default_keychain: true, unlock: true, timeout: 3600,
        lock_when_sleeps: false
      )
      match(type: "appstore", readonly: true, api_key: api_key,
            keychain_name: keychain_name, keychain_password: keychain_password)
    else
      match(type: "appstore", readonly: true, api_key: api_key)
    end

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      team_id: "DJ6Z29BM4D",
      code_sign_identity: "Apple Distribution",
      bundle_identifier: "uz.ketamiz.app",
      profile_name: "match AppStore uz.ketamiz.app",
      targets: ["Runner"]
    )

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          "uz.ketamiz.app" => "match AppStore uz.ketamiz.app"
        }
      }
    )

    # App Store'ga yuklab, review'ga jo'natish.
    # submit_for_review: true -> avtomatik review navbatiga qo'yadi
    # automatic_release: true -> review o'tgach avtomatik publik chiqaradi
    upload_to_app_store(
      api_key: api_key,
      submit_for_review: true,
      automatic_release: true,
      force: true,                       # metadata HTML preview'ini o'tkazib yuborish
      precheck_include_in_app_purchases: false,
      submission_information: {
        export_compliance_uses_encryption: false,
        add_id_info_uses_idfa: false
      }
    )
  end

  desc "Faqat IPA build (upload'siz) — lokal sinov uchun, API key kerak emas"
  lane :build_only do
    match(type: "appstore", readonly: true)

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      team_id: "DJ6Z29BM4D",
      code_sign_identity: "Apple Distribution",
      bundle_identifier: "uz.ketamiz.app",
      profile_name: "match AppStore uz.ketamiz.app",
      targets: ["Runner"]
    )

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          "uz.ketamiz.app" => "match AppStore uz.ketamiz.app"
        }
      }
    )
  end
end
